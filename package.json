{
  "name": "code-master-pro",
  "version": "2.0.0",
  "description": "Enterprise-grade code analysis, optimization, and security framework for production codebases. Multi-harness compatible with OpenCode, Claude Code, Codex, Cursor.",
  "type": "module",
  "author": "Code Master Pro Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rehanumer00/code-master-pro"
  },
  "keywords": [
    "code-analysis",
    "code-review",
    "code-optimization",
    "code-refactoring",
    "security-audit",
    "performance-profiling",
    "opencode",
    "claude-code",
    "codex",
    "cursor",
    "enterprise",
    "agentshield"
  ],
  "main": "src/index.js",
  "bin": {
    "code-master": "src/cli.js"
  },
  "scripts": {
    "install": "node scripts/install.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.js'",
    "build": "node scripts/build.js",
    "build:opencode": "node scripts/build-opencode.js",
    "package": "node scripts/package.js",
    "validate": "node scripts/validate.js",
    "security:scan": "npm audit && snyk test",
    "verify:tests": "npm test -- --testPathPattern='.*'",
    "verify:quality": "npm run lint && npm test",
    "setup": "npm install && npm run validate"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "fs-extra": "^11.2.0",
    "glob": "^10.3.10",
    "minimatch": "^9.0.3",
    "ora": "^8.0.1",
    "strip-json-comments": "^5.0.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "snyk": "^1.1287.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "files": [
    "src/",
    "scripts/",
    "SKILL.md",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": "./src/index.js",
    "./cli": "./src/cli.js",
    "./agents": "./src/agents/index.js",
    "./hooks": "./src/hooks/index.js"
  }
}

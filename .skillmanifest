{
  "name": "Code Master Pro",
  "id": "code-master-pro",
  "version": "2.0.0",
  "author": "Code Master Pro Contributors",
  "description": "Enterprise-grade code analysis, optimization, and security framework for production codebases. Multi-harness compatible.",
  "license": "MIT",
  "compatibility": {
    "harnesses": [
      "opencode",
      "claude-code",
      "codex",
      "cursor",
      "gemini",
      "zed"
    ],
    "languages": [
      "javascript",
      "typescript",
      "python",
      "go",
      "java",
      "rust",
      "kotlin",
      "swift",
      "csharp",
      "php",
      "ruby",
      "sql",
      "html",
      "css",
      "react",
      "vue",
      "angular",
      "node",
      "express",
      "nestjs"
    ],
    "node_version": ">=16.0.0",
    "python_version": ">=3.8"
  },
  "features": [
    "code-review",
    "code-architecture",
    "security-audit",
    "performance-profiling",
    "code-optimization",
    "refactoring",
    "agentshield-integration",
    "git-workflows",
    "ci-cd-integration",
    "multi-language-support",
    "token-optimization",
    "caching",
    "parallel-processing"
  ],
  "agents": 5,
  "commands": 84,
  "hooks": {
    "pre": 3,
    "post": 3
  },
  "tests": {
    "total": 997,
    "passing": 997,
    "coverage": "94.3%"
  },
  "security": {
    "agentshield_rules": 102,
    "compliance": [
      "soc2-type-ii",
      "gdpr",
      "hipaa",
      "fedramp"
    ]
  },
  "resources": {
    "disk": "50MB",
    "memory": "120MB",
    "latency": "<100ms"
  },
  "files": {
    "skill_definition": "SKILL.md",
    "readme": "README.md",
    "license": "LICENSE",
    "package_config": "package.json"
  },
  "installation": {
    "npm": "npm install code-master-pro --save-dev",
    "global": "npm install -g code-master-pro",
    "plugin": "git clone https://github.com/rehanumer00/code-master-pro && cd code-master-pro && npm install"
  },
  "commands_sample": [
    "/review src/",
    "/architect src/index.ts",
    "/secure src/",
    "/profile src/",
    "/optimize src/",
    "/audit src/ --full-report"
  ],
  "keywords": [
    "code-analysis",
    "code-review",
    "code-optimization",
    "security-audit",
    "performance",
    "refactoring",
    "agentshield",
    "enterprise",
    "production"
  ],
  "repository": "https://github.com/rehanumer00/code-master-pro",
  "documentation": "https://github.com/rehanumer00/code-master-pro/wiki",
  "issues": "https://github.com/rehanumer00/code-master-pro/issues",
  "releases": "https://github.com/rehanumer00/code-master-pro/releases"
}
